---
import formatIndex from "../data/format-index.json"
import { GITHUB_URL } from "../lib/nav"

interface Props {
  base: string
  current?: "home" | "docs" | "formats"
}

const { base, current } = Astro.props
const withBase = (path: string) =>
  `${base}${path.replace(/^\//, "")}`.replace(/\/{2,}/g, "/")
const formatCount = formatIndex.length
---

<header
  class="animate-fade-in sticky top-0 z-50 border-b border-border/80 bg-background/75 backdrop-blur-md"
>
  <nav
    class="mx-auto flex h-14 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6"
  >
    <a
      href="https://www.ethira.dev"
      class="inline-flex items-center gap-2 font-brand text-lg font-medium tracking-tight text-foreground transition-colors hover:text-primary"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Ethira"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="826.7 406.7 266.6 266.6"
        class="size-5 shrink-0 fill-current"
        aria-hidden="true"
      >
        <path
          d="M960,406.7c-73.5,0-133.3,59.8-133.3,133.3s59.8,133.3,133.3,133.3,122.7-49.8,132-114.3h-21c-7.8,21.1-28,36.1-51.7,36.1s-55.1-24.7-55.1-55.1h129.2c0-.9,0-1.8,0-2.7-1.4-72.3-60.7-130.7-133.3-130.7ZM960,654.3c-63,0-114.3-51.3-114.3-114.3s51.3-114.3,114.3-114.3,37.7,4.9,53.7,13.4c-7.7-1.8-15.8-2.8-24.1-2.8-57.2,0-103.8,46.5-103.8,103.8s46.5,103.8,103.8,103.8,16.4-1,24.1-2.8c-16,8.6-34.3,13.4-53.7,13.4h0ZM945.1,540c0,40.9,33.2,74.1,74.1,74.1s9.2-.4,13.6-1.3c-12.7,7.6-27.5,11.9-43.3,11.9-46.7,0-84.8-38-84.8-84.8s38-84.7,84.8-84.7,30.6,4.4,43.3,11.9c-4.4-.8-9-1.3-13.6-1.3-40.9,0-74.1,33.2-74.1,74.1ZM967.5,521c7.8-21.1,28-36.1,51.7-36.1s44,15,51.7,36.1h-103.4Z"
        ></path>
      </svg>
      <span>ethira</span>
    </a>
    <div class="flex items-center gap-1 sm:gap-2">
      <a
        href={withBase("/")}
        class:list={[
          "rounded-md px-3 py-1.5 text-sm transition-colors",
          current === "home"
            ? "text-primary"
            : "text-muted-foreground hover:text-foreground",
        ]}
      >
        Home
      </a>
      <a
        href={withBase("/formats/")}
        class:list={[
          "inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-sm transition-colors",
          current === "formats"
            ? "text-primary"
            : "text-muted-foreground hover:text-foreground",
        ]}
      >
        <span class="hidden sm:inline">Supported Formats</span>
        <span class="sm:hidden">Formats</span>
        <span
          class="inline-flex min-w-[1.5rem] items-center justify-center rounded-md bg-primary/15 px-1.5 py-0.5 font-mono text-[11px] font-medium tabular-nums text-primary"
        >
          {formatCount}
        </span>
      </a>
      <a
        href={withBase("/docs/quick-start/")}
        class:list={[
          "rounded-md px-3 py-1.5 text-sm transition-colors",
          current === "docs"
            ? "text-primary"
            : "text-muted-foreground hover:text-foreground",
        ]}
      >
        Docs
      </a>
      <a
        href={withBase("/docs/install/")}
        class="rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        Install
      </a>
      <a
        href={GITHUB_URL}
        class="rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
    </div>
  </nav>
</header>
