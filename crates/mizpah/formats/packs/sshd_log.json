{
    "sshd_log": {
        "title": "OpenSSH sshd",
        "description": "OpenSSH authentication success/failure lines",
        "regex": {
            "std": {
                "pattern": "^(?:(?<syslog_pri><\\d+>)?(?<syslog_ts>\\w{3}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2})\\s+(?<syslog_host>\\S+)\\s+)?sshd\\[(?<pid>\\d+)\\]:\\s+(?<body>(?:Accepted|Failed|Invalid user|Disconnected from|Connection (?:closed|reset)|pam_unix\\(sshd:auth\\):).*)"
            }
        },
        "sample": [
            {
                "line": "Jan  1 00:00:00 host sshd[1234]: Accepted publickey for alice from 1.2.3.4 port 50000 ssh2"
            },
            {
                "line": "Jan  1 00:00:00 host sshd[1235]: Failed password for invalid user root from 1.2.3.4 port 50001 ssh2"
            }
        ],
        "url": "https://www.openssh.com/",
        "body-field": "body"
    }
}
