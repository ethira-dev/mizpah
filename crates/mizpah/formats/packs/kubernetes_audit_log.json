{
    "kubernetes_audit_log": {
        "title": "Kubernetes audit",
        "description": "Kubernetes audit API events",
        "file-type": "json",
        "json": true,
        "timestamp-field": "requestReceivedTimestamp",
        "line-format": [
            {
                "field": "requestReceivedTimestamp"
            },
            " ",
            {
                "field": "verb"
            },
            " ",
            {
                "field": "user"
            },
            " ",
            {
                "field": "objectRef"
            }
        ],
        "url": "https://kubernetes.io/docs/tasks/debug/debug-cluster/audit/",
        "body-field": "verb",
        "sample": [
            {
                "line": "{\"kind\":\"Event\",\"apiVersion\":\"audit.k8s.io/v1\",\"level\":\"Metadata\",\"auditID\":\"11111111-2222-3333-4444-555555555555\",\"stage\":\"ResponseComplete\",\"requestURI\":\"/api/v1/namespaces/default/pods\",\"verb\":\"list\",\"user\":{\"username\":\"system:serviceaccount:default:default\",\"groups\":[\"system:serviceaccounts\"]},\"sourceIPs\":[\"10.0.0.1\"],\"objectRef\":{\"resource\":\"pods\",\"namespace\":\"default\",\"apiVersion\":\"v1\"},\"responseStatus\":{\"metadata\":{},\"code\":200},\"requestReceivedTimestamp\":\"2020-01-01T00:00:00.000000Z\",\"stageTimestamp\":\"2020-01-01T00:00:00.001000Z\"}"
            }
        ]
    }
}
