{
    "slog_json_log": {
        "title": "Go slog JSON",
        "description": "Go log/slog JSONHandler objects (time, level, msg)",
        "url": "https://pkg.go.dev/log/slog",
        "file-type": "json",
        "timestamp-field": "time",
        "level-field": "level",
        "body-field": "msg",
        "line-format": [
            { "field": "time" },
            " ",
            { "field": "level" },
            " ",
            { "field": "msg" }
        ],
        "sample": [
            {
                "line": "{\"time\":\"2020-01-01T00:00:00.000Z\",\"level\":\"INFO\",\"msg\":\"server listening\"}"
            },
            {
                "line": "{\"time\":\"2020-01-01T00:00:00.000Z\",\"level\":\"ERROR\",\"msg\":\"request failed\",\"err\":\"timeout\"}"
            }
        ]
    }
}
