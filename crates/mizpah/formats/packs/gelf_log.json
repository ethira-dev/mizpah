{
    "gelf_log": {
        "title": "GELF",
        "description": "Graylog Extended Log Format",
        "file-type": "json",
        "json": true,
        "timestamp-field": "timestamp",
        "line-format": [
            {
                "field": "timestamp"
            },
            " ",
            {
                "field": "level"
            },
            " ",
            {
                "field": "host"
            },
            " ",
            {
                "field": "short_message"
            }
        ],
        "url": "https://go2docs.graylog.org/current/getting_in_log_data/gelf.html",
        "level-field": "level",
        "body-field": "short_message",
        "sample": [
            {
                "line": "{\"version\":\"1.1\",\"host\":\"example.org\",\"short_message\":\"A short message\",\"timestamp\":1577836800.123,\"level\":3,\"_user_id\":42}"
            }
        ]
    }
}
