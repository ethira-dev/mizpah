{
    "sophos_log": {
        "title": "Sophos",
        "description": "Sophos Central / XG event JSON",
        "file-type": "json",
        "json": true,
        "timestamp-field": "created_at",
        "line-format": [
            {
                "field": "created_at"
            },
            " ",
            {
                "field": "severity"
            },
            " ",
            {
                "field": "name"
            },
            " ",
            {
                "field": "type"
            },
            " ",
            {
                "field": "source"
            }
        ],
        "url": "https://www.sophos.com/",
        "level-field": "severity",
        "body-field": "name",
        "sample": [
            {
                "line": "{\"created_at\":\"2020-01-01T00:00:00.000Z\",\"id\":\"abc123\",\"name\":\"Malware detected\",\"type\":\"Event::Endpoint::Threat::Detected\",\"severity\":\"high\",\"source\":\"sophoscentral\",\"location\":\"workstation01\",\"source_info\":{\"ip\":\"10.0.0.5\"}}"
            }
        ]
    }
}
