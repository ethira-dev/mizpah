{
    "otel_collector_log": {
        "title": "OpenTelemetry Collector file exporter",
        "description": "OTLP JSON logs lines from the Collector file exporter (resourceLogs envelopes; JSON format only)",
        "file-type": "json",
        "json": true,
        "match-keys": ["resourceLogs"],
        "line-format": [
            { "field": "resourceLogs" }
        ],
        "url": "https://github.com/open-telemetry/opentelemetry-collector-contrib/tree/main/exporter/fileexporter",
        "sample": [
            {
                "line": "{\"resourceLogs\":[{\"resource\":{\"attributes\":[{\"key\":\"service.name\",\"value\":{\"stringValue\":\"payment-api\"}}]},\"scopeLogs\":[{\"scope\":{\"name\":\"opentelemetry.instrumentation.fastapi\"},\"logRecords\":[{\"timeUnixNano\":\"1577836800000000000\",\"severityNumber\":17,\"severityText\":\"ERROR\",\"body\":{\"stringValue\":\"payment failed\"},\"traceId\":\"a1b2c3d4e5f60718293a4b5c6d7e8f90\",\"spanId\":\"1a2b3c4d5e6f7890\"}]}]}]}"
            }
        ]
    }
}
