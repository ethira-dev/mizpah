{
    "checkpoint_log": {
        "title": "Check Point",
        "description": "Check Point firewall syslog-style logs",
        "regex": {
            "std": {
                "pattern": "^(?:(?<syslog_pri><\\d+>)?(?<syslog_ts>\\w{3}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2})\\s+(?<syslog_host>\\S+)\\s+)?(?<body>\\[Action:\\s*(?<action>[^;]+);.*Product:\\s*(?<product>[^\\]]+)\\].*)$"
            }
        },
        "sample": [
            {
                "line": "Jan  1 00:00:00 cp-gw [Action: Accept; Src: 10.0.0.1; Dst: 1.2.3.4; Proto: tcp; Product: VPN-1 & FireWall-1]"
            }
        ],
        "url": "https://www.checkpoint.com/",
        "level-field": "action",
        "level": {
            "info": "Accept|accept",
            "error": "Drop|drop|Reject|reject"
        },
        "body-field": "body"
    }
}
