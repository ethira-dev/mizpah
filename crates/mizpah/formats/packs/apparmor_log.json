{
    "apparmor_log": {
        "title": "AppArmor",
        "description": "AppArmor DENIED/ALLOWED audit lines",
        "regex": {
            "std": {
                "pattern": "^(?:(?<syslog_pri><\\d+>)?(?<syslog_ts>\\w{3}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2})\\s+(?<syslog_host>\\S+)\\s+)?(?<body>type=AVC msg=audit\\(.*\\): apparmor=\\\"(?:DENIED|ALLOWED)\\\".*)"
            }
        },
        "sample": [
            {
                "line": "Jan  1 00:00:00 host type=AVC msg=audit(1577836800.000:456): apparmor=\"DENIED\" operation=\"open\" profile=\"/usr/bin/evince\" name=\"/etc/shadow\" pid=1234 comm=\"evince\""
            }
        ],
        "url": "https://apparmor.net/",
        "body-field": "body"
    }
}
