{
    "gunicorn_log": {
        "title": "Gunicorn",
        "description": "Gunicorn error and access log lines",
        "url": "https://docs.gunicorn.org/en/stable/logging.html",
        "regex": {
            "error": {
                "pattern": "^\\[(?<timestamp>\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}(?: [+-]\\d{4})?)\\] \\[(?<pid>\\d+)\\] \\[(?<level>DEBUG|INFO|WARNING|ERROR|CRITICAL)\\] (?<body>.*)$"
            },
            "access": {
                "pattern": "^(?<client>\\S+)\\s+\\S+\\s+\\S+\\s+\\[(?<timestamp>[^\\]]+)\\]\\s+\"(?<method>\\w+)\\s+(?<path>[^\"]+)\\s+(?<proto>HTTP/[^\"]+)\"\\s+(?<status>\\d{3})\\s+(?<size>\\S+)(?:\\s+\"(?<referer>[^\"]*)\"\\s+\"(?<agent>[^\"]*)\")?$"
            }
        },
        "level-field": "level",
        "body-field": "body",
        "timestamp-field": "timestamp",
        "level": {
            "debug": "DEBUG",
            "info": "INFO",
            "warn": "WARNING",
            "error": "ERROR",
            "critical": "CRITICAL"
        },
        "sample": [
            {
                "line": "[2020-01-01 00:00:00 +0000] [1234] [INFO] Starting gunicorn 21.2.0"
            },
            {
                "line": "127.0.0.1 - - [01/Jan/2020:00:00:00 +0000] \"GET / HTTP/1.1\" 200 123"
            }
        ]
    }
}
