{
    "bind_dns_log": {
        "title": "BIND DNS",
        "description": "BIND query log lines",
        "regex": {
            "std": {
                "pattern": "^(?:(?<syslog_pri><\\d+>)?(?<syslog_ts>\\w{3}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2})\\s+(?<syslog_host>\\S+)\\s+)?(?:named(?:\\[\\d+\\])?:\\s+)?(?<body>client\\s+.+?:\\s+query:\\s+.*)$"
            }
        },
        "sample": [
            {
                "line": "Jan  1 00:00:00 host named[1234]: client @0x7f 1.2.3.4#50000 (example.com): query: example.com IN A +E(0)K (10.0.0.53)"
            }
        ],
        "url": "https://www.isc.org/bind/",
        "body-field": "body"
    }
}
