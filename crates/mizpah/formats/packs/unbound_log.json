{
    "unbound_log": {
        "title": "Unbound DNS",
        "description": "Unbound resolver info / query log lines",
        "regex": {
            "std": {
                "pattern": "^(?:(?<syslog_pri><\\d+>)?(?<syslog_ts>\\w{3}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2})\\s+(?<syslog_host>\\S+)\\s+)?unbound(?:\\[\\d+\\])?:\\s+\\[(?<thread>\\d+):(?<level>\\d+)\\] (?<body>.*)$"
            }
        },
        "sample": [
            {
                "line": "Jan  1 00:00:00 host unbound[1234]: [1234:0] info: 1.2.3.4 example.com. A IN"
            }
        ],
        "url": "https://nlnetlabs.nl/projects/unbound/",
        "body-field": "body"
    }
}
