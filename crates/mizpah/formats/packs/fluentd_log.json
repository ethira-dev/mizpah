{
    "fluentd_log": {
        "title": "Fluentd / Fluent Bit",
        "description": "Fluentd/Fluent Bit JSON log records",
        "file-type": "json",
        "json": true,
        "timestamp-field": "time",
        "line-format": [
            {
                "field": "time"
            },
            " ",
            {
                "field": "level"
            },
            " ",
            {
                "field": "message"
            },
            " ",
            {
                "field": "container_name"
            }
        ],
        "url": "https://docs.fluentbit.io/",
        "level-field": "level",
        "body-field": "message",
        "sample": [
            {
                "line": "{\"time\":\"2020-01-01T00:00:00.000Z\",\"log\":\"hello from fluent\",\"message\":\"hello from fluent\",\"level\":\"info\",\"container_name\":\"/k8s_app\",\"kubernetes\":{\"pod_name\":\"app-0\",\"namespace_name\":\"default\"}}"
            }
        ]
    }
}
