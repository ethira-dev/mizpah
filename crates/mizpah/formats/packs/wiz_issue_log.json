        "body-field": "type",
        "sample": [
            {
                "line": "{\"id\":\"issue-1\",\"createdAt\":\"2020-01-01T00:00:00Z\",\"updatedAt\":\"2020-01-01T00:00:00Z\",\"severity\":\"HIGH\",\"status\":\"OPEN\",\"type\":\"TOXIC_COMBINATION\",\"entity\":{\"id\":\"res-1\",\"name\":\"prod-db\",\"type\":\"VIRTUAL_MACHINE\"},\"projects\":[{\"id\":\"p1\",\"name\":\"Production\"}]}"
