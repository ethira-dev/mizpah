{
    "gcp_cloud_logging_log": {
        "title": "GCP Cloud Logging",
        "description": "Google Cloud Logging LogEntry JSON",
        "file-type": "json",
        "json": true,
        "timestamp-field": "timestamp",
        "line-format": [
            {
                "field": "timestamp"
            },
            " ",
            {
                "field": "severity"
            },
            " ",
            {
                "field": "textPayload"
            },
            " ",
            {
                "field": "logName"
            }
        ],
        "url": "https://cloud.google.com/logging/docs/reference/v2/rest/v2/LogEntry",
        "level-field": "severity",
        "body-field": "textPayload",
        "sample": [
            {
                "line": "{\"timestamp\":\"2020-01-01T00:00:00.000Z\",\"severity\":\"ERROR\",\"logName\":\"projects/demo/logs/stdout\",\"resource\":{\"type\":\"gce_instance\",\"labels\":{\"instance_id\":\"123\"}},\"textPayload\":\"something failed\",\"insertId\":\"abc\"}"
            }
        ]
    }
}
