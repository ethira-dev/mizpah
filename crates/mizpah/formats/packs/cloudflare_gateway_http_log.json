{
    "cloudflare_gateway_http_log": {
        "title": "Cloudflare Gateway HTTP",
        "description": "Cloudflare Logpush Gateway HTTP",
        "file-type": "json",
        "json": true,
        "timestamp-field": "Datetime",
        "line-format": [
            {
                "field": "Datetime"
            },
            " ",
            {
                "field": "Action"
            },
            " ",
            {
                "field": "URL"
            }
        ],
        "url": "https://developers.cloudflare.com/logs/logpush/",
        "level-field": "Action",
        "body-field": "URL",
        "sample": [
            {
                "line": "{\"Datetime\":\"2020-01-01T00:00:00Z\",\"Action\":\"allow\",\"URL\":\"https://example.com/\",\"UserID\":\"u1\",\"Email\":\"alice@example.com\",\"SourceIP\":\"1.2.3.4\",\"HTTPHost\":\"example.com\",\"AccountID\":\"acc\"}"
            }
        ]
    }
}
