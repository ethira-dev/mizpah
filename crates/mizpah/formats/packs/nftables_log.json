{
    "nftables_log": {
        "title": "nftables",
        "description": "nftables / nf_tables LOG lines",
        "regex": {
            "std": {
                "pattern": "^(?:(?<syslog_pri><\\d+>)?(?<syslog_ts>\\w{3}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2})\\s+(?<syslog_host>\\S+)\\s+)?(?:kernel:\\s+)?(?<body>(?:\\[\\s*)?(?:nftables|nf_tables)[^\\]]*\\]?.* SRC=[\\w.:-]+ DST=[\\w.:-]+.*)$"
            }
        },
        "sample": [
            {
                "line": "Jan  1 00:00:00 host kernel: [nftables DROP] IN=eth0 OUT= SRC=1.2.3.4 DST=10.0.0.5 PROTO=TCP SPT=12345 DPT=443"
            }
        ],
        "url": "https://wiki.nftables.org/",
        "body-field": "body"
    }
}
