{
    "cloudflare_gateway_dns_log": {
        "title": "Cloudflare Gateway DNS",
        "description": "Cloudflare Logpush Gateway DNS",
        "file-type": "json",
        "json": true,
        "timestamp-field": "Datetime",
        "line-format": [
            {
                "field": "Datetime"
            },
            " ",
            {
                "field": "Action"
            },
            " ",
            {
                "field": "QueryName"
            }
        ],
        "url": "https://developers.cloudflare.com/logs/logpush/",
        "level-field": "Action",
        "body-field": "QueryName",
        "sample": [
            {
                "line": "{\"Datetime\":\"2020-01-01T00:00:00Z\",\"Action\":\"allow\",\"QueryName\":\"malware.example\",\"QueryType\":\"A\",\"Email\":\"alice@example.com\",\"SourceIP\":\"1.2.3.4\",\"ResolvedIPs\":[\"1.2.3.4\"]}"
            }
        ]
    }
}
