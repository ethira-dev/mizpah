{
    "nginx_json_access_log": {
        "title": "Nginx JSON access",
        "description": "Nginx access log in JSON via log_format",
        "file-type": "json",
        "json": true,
        "timestamp-field": "time_local",
        "line-format": [
            {
                "field": "time_local"
            },
            " ",
            {
                "field": "status"
            },
            " ",
            {
                "field": "request"
            },
            " ",
            {
                "field": "remote_addr"
            }
        ],
        "url": "https://nginx.org/en/docs/http/ngx_http_log_module.html",
        "body-field": "request",
        "sample": [
            {
                "line": "{\"time_local\":\"01/Jan/2020:00:00:00 +0000\",\"remote_addr\":\"1.2.3.4\",\"request\":\"GET / HTTP/1.1\",\"status\":200,\"body_bytes_sent\":123,\"http_user_agent\":\"curl/7.0\",\"request_time\":0.001,\"host\":\"example.com\"}"
            }
        ]
    }
}
