{
    "cloudflare_firewall_log": {
        "title": "Cloudflare Firewall",
        "description": "Cloudflare Logpush firewall_events",
        "file-type": "json",
        "json": true,
        "timestamp-field": "Datetime",
        "line-format": [
            {
                "field": "Datetime"
            },
            " ",
            {
                "field": "Action"
            },
            " ",
            {
                "field": "RayID"
            }
        ],
        "url": "https://developers.cloudflare.com/logs/logpush/",
        "level-field": "Action",
        "body-field": "RayID",
        "sample": [
            {
                "line": "{\"Datetime\":\"2020-01-01T00:00:00Z\",\"Action\":\"block\",\"ClientIP\":\"1.2.3.4\",\"ClientRequestHTTPHost\":\"example.com\",\"ClientRequestPath\":\"/\",\"RayID\":\"6b1abc0000000000\",\"Source\":\"waf\",\"RuleID\":\"abc\",\"EdgeResponseStatus\":403}"
            }
        ]
    }
}
